# ============================================
# QUICK START FOR JUDGES/REVIEWERS
# ============================================
# 1. Copy this file to .env
# 2. Fill in QDRANT_URL and QDRANT_API_KEY (provided separately)
# 3. Model downloads automatically from HuggingFace (~24 MB)
# 4. Run: uvicorn main:app --reload

# Qdrant Vector Database (Cloud - Provided by Submission)
QDRANT_URL=https://your-qdrant-url.cloud.qdrant.io
QDRANT_API_KEY=your_api_key_here

# Fine-Tuned LLM Model
# Model auto-downloads from: https://huggingface.co/Santhoshkumarp/phi35-maintenance-wizard-lora
USE_LOCAL_MODEL=true
LOCAL_MODEL_BASE=microsoft/Phi-3.5-mini-instruct
LOCAL_MODEL_ADAPTER=Santhoshkumarp/phi35-maintenance-wizard-lora

# Application Settings
DEBUG=False
